{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "litellm/gemini-3.1-pro",
  "disabled_providers": [],
  "logLevel": "DEBUG",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Quiq LiteLLM Proxy",
      "options": {
        "baseURL": "https://quiqgpt-proxy-east.quiq.sh/v1",
        "includeUsage": true,
      },
      "models": {
        "gemini-3-flash": {
          "name": "Gemini 3 Flash",
          "cost": {
            "input": 0.5,
            "output": 3,
            "cache_read": 0.05
          },
          "limit": {
            "input": 1048576,
            "output": 65536,
            "context": 1114112
          }
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "cost": {
            "input": 2,
            "output": 12,
            "cache_read": 0.2,
            "context_over_200k": {
              "input": 4,
              "output": 18,
              "cache_read": 0.4
            }
          },
          "limit": {
            "input": 1048576,
            "output": 65536,
            "context": 1114112
          }
        },
        "claude-4.6-sonnet": {
          "name": "Claude 4.6 Sonnet",
          "cost": {
            "input": 3,
            "output": 15,
            "cache_read": 0.3,
            "cache_write": 3.75
          },
          "limit": {
            "input": 1000000,
            "output": 64000,
            "context": 1064000
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "rm *": "ask",
      "git *": "ask",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "open https://gitlab.quiq.sh/*": "allow",
      "$QUIQ_SRC_ROOT/.scripts/*": "allow",
      "git -C $QUIQ_SRC_ROOT/* remote get-url origin": "allow",
      "git diff*": "allow",
      "echo *": "allow",
      "qdev *": "allow",
      "qdev *--yes*": "ask"
    },
    "edit": {
      "*": "ask",
      "*.scala": "allow",
      "*.java": "allow",
      "*.rs": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.gradle": "allow",
      "*.py": "allow",
      "*.md": "allow",
      "*.lua": "allow"
    },
    "read": {
      "*": "ask",
      "*.scala": "allow",
      "*.java": "allow",
      "*.rs": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.gradle": "allow",
      "*.py": "allow",
      "*.log": "allow",
      "*.md": "allow",
      "*.lua": "allow",
      "*.toml": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "config-override.json": "deny",
      "/Users/jared.weiss/Dev/quiq/.claude/skills-library/review-backend.md": "allow"
    },
    "list": {
      "*": "allow"
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": {
      "*": "ask",
      "~/Dev/quiq*": "allow"
    },
    "doom_loop": "deny",
    "skill": "allow"
  }
}
