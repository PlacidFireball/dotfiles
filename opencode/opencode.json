{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "litellm/claude-4.6-sonnet",
  "disabled_providers": [
  ],
  "logLevel": "DEBUG",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Quiq LiteLLM Proxy",
      "options": {
        "baseURL": "https://quiqgpt-proxy.quiq.sh/v1",
        "apiKey": "curl -fsSL https://static.quiq-cdn.com/provision/install.sh | bash"
      },
      "models": {
        "gemini-3-flash": {
          "name": "Gemini 3 Flash"
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro"
        },
        "claude-4.6-sonnet": {
          "name": "Claude 4.6 Sonnet"
        },
        "gpt-5.2": {
          "name": "GPT 5.2"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "rm *": "ask",
      "git *": "ask",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
    },
    "edit": {
      "*": "ask",
      "*.scala": "allow",
      "*.java": "allow",
      "*.rs": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.gradle": "allow",
      "*.py": "allow",
      "*.md": "allow",
    },
    "read": {
      "*.scala": "allow",
      "*.java": "allow",
      "*.rs": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.gradle": "allow",
      "*.py": "allow",
      "*.log": "allow",
      "*.md": "allow",
      "*": "ask",
      "*.env": "deny",
      "*.env.*": "deny",
      "config-override.json": "deny",
    },
    "list": {
      "*": "allow"
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "doom_loop": "deny",
    "skill": "allow",
  }
}
